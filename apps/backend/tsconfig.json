{
	"compilerOptions": {
		// Base Options
		"esModuleInterop": true,
		"skipLibCheck": true,
		"target": "ES2024",

		// Bundler Mode
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,

		// Linting
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true
	},
	"include": ["src"]
}
